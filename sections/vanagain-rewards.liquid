<section class="section section--page-width vanagain-rewards">
  <div class="vanagain-rewards__hero">
    <p class="vanagain-rewards__eyebrow">Rewards</p>
    <h1>VanAgain Rewards</h1>
    <p>Join our rewards program to earn points on every order and redeem them for savings on future parts purchases.</p>
  </div>

  <div class="vanagain-rewards__grid">
    <article>
      <h2>How It Works</h2>
      <ol>
        <li>Create your customer account.</li>
        <li>Place orders and earn points automatically.</li>
        <li>Redeem points at checkout for discounts.</li>
      </ol>
    </article>

    <article>
      <h2>More Ways To Earn</h2>
      <ul>
        <li>Follow us for community updates.</li>
        <li>Complete your profile details.</li>
        <li>Look for seasonal bonus-point campaigns.</li>
      </ul>
    </article>
  </div>

  <div class="vanagain-rewards__cta">
    <h2>Start Earning Today</h2>
    <p>Sign in to your account or browse parts to place your next order.</p>
    <div class="vanagain-rewards__actions">
      <a class="button" href="{{ routes.account_login_url }}">Sign In</a>
      <a class="button button-secondary" href="{{ routes.all_products_collection_url }}?filter.v.availability=1">Shop Parts</a>
    </div>
  </div>
</section>

{% stylesheet %}
  .vanagain-rewards {
    padding-block: 2rem 3rem;
    display: grid;
    gap: 1.25rem;
  }

  .vanagain-rewards__eyebrow {
    margin: 0;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #1a6b8a;
    font-weight: 700;
  }

  .vanagain-rewards__hero h1 {
    margin: 0.3rem 0 0.6rem;
    font-size: clamp(1.8rem, 3.3vw, 2.8rem);
  }

  .vanagain-rewards__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .vanagain-rewards__grid article {
    border: 1px solid #dce8ef;
    border-radius: 14px;
    padding: 1rem;
    background: #f8fcfe;
  }

  .vanagain-rewards__grid h2 {
    margin-top: 0;
  }

  .vanagain-rewards__grid ul,
  .vanagain-rewards__grid ol {
    margin: 0;
    padding-left: 1rem;
    display: grid;
    gap: 0.35rem;
  }

  .vanagain-rewards__cta {
    border-radius: 16px;
    padding: 1.1rem;
    background: linear-gradient(180deg, #eff8fd 0%, #e4f2fa 100%);
    border: 1px solid #cfe3ef;
  }

  .vanagain-rewards__cta h2 {
    margin: 0;
  }

  .vanagain-rewards__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: 0.75rem;
  }

  @media (max-width: 860px) {
    .vanagain-rewards__grid {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "VanAgain Rewards",
  "settings": [],
  "presets": [
    {
      "name": "VanAgain Rewards"
    }
  ]
}
{% endschema %}
