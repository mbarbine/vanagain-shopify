

<script
  src="{{ 'results-list.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

{% javascript %}
  const url = new URL(window.location.href);
  const legacyTagFilter = url.searchParams.get('filter.p.tag');
  const tagCollectionHandles = new Set([
    '68-79-bus',
    '80-83-air-cooled-vanagon',
    '82-84-diesel-vanagon',
    '83-85-19l-vanagon',
    '86-92-21l-vanagon',
    '92-96-25l-eurovan',
    '97-03-28l-eurovan',
    'accessories',
    'air-intake',
    'body-electrical',
    'body-mechanical-trim',
    'brakes',
    'camper-parts',
    'climate-control',
    'clutch',
    'coolant-system',
    'drive-belts',
    'drive-shaft',
    'electrical-items',
    'engine-conversion-parts',
    'engine-electrical',
    'engine-parts',
    'exhaust-parts',
    'featured-items',
    'fuel-delivery',
    'fuel-injection',
    'suspension-and-steering',
    'tires',
    'tools',
    'tools-and-hardware',
    'transmission-drivetrain',
    'tune-up-parts',
    'wheels',
  ]);
  const tagCollectionAliases = new Map([
    ['68-79-bus', '68-79-bus'],
    ['80-83-air-cooled-vanagon', '80-83-air-cooled-vanagon'],
    ['82-84-diesel-vanagon', '82-84-diesel-vanagon'],
    ['83-85-19l-vanagon', '83-85-19l-vanagon'],
    ['86-92-21l-vanagon', '86-92-21l-vanagon'],
    ['92-96-25l-eurovan', '92-96-25l-eurovan'],
    ['97-03-28l-eurovan', '97-03-28l-eurovan'],
    ['body-mechanical-and-trim', 'body-mechanical-trim'],
    ['transmission-and-drivetrain', 'transmission-drivetrain'],
  ]);
  const normalizeLegacyTagFilter = (value) =>
    value
      .trim()
      .toLowerCase()
      .replace(/&/g, 'and')
      .replace(/\./g, '')
      .replace(/\s+/g, '-')
      .replace(/-+/g, '-');
  const canonicalLegacyTagFilter = legacyTagFilter
    ? tagCollectionHandles.has(legacyTagFilter)
      ? legacyTagFilter
      : tagCollectionAliases.get(normalizeLegacyTagFilter(legacyTagFilter))
    : undefined;

  if (
    canonicalLegacyTagFilter &&
    url.pathname === '/collections/all'
  ) {
    url.searchParams.delete('filter.p.tag');
    url.pathname = `${url.pathname}/${canonicalLegacyTagFilter}`;
    url.hash = 'ResultsList';
    window.location.replace(url.toString());
  }

  const shouldFocusResults =
    url.hash === '#ResultsList' ||
    url.pathname.startsWith('/collections/all/') ||
    url.searchParams.has('filter.v.availability') ||
    url.searchParams.has('view') ||
    url.searchParams.has('sort_by') ||
    url.searchParams.has('filter.p.tag');

  document.addEventListener(
    'DOMContentLoaded',
    () => {
      const toolbar = document.querySelector('[data-vanagain-catalog-toolbar]');
      if (!toolbar) return;

      const toolbarUrl = new URL(window.location.href);
      const viewParam = toolbarUrl.searchParams.get('view') || toolbar.dataset.currentView || 'grid-24';
      const [initialLayout = 'grid', initialPageSize = '24'] = viewParam.split('-');
      const pageSizeSelect = toolbar.querySelector('[data-vanagain-page-size-select]');
      const sortSelect = toolbar.querySelector('[data-vanagain-sort-select]');
      const layoutLinks = toolbar.querySelectorAll('[data-vanagain-layout-link]');

      const navigateCatalog = (layout, pageSize, sortBy) => {
        const nextUrl = new URL(window.location.href);
        nextUrl.searchParams.set('view', `${layout}-${pageSize}`);
        nextUrl.searchParams.delete('page');
        if (sortBy) {
          nextUrl.searchParams.set('sort_by', sortBy);
        }
        nextUrl.hash = 'ResultsList';
        window.location.assign(nextUrl.toString());
      };

      layoutLinks.forEach((link) => {
        const layout = link.dataset.layout || initialLayout;
        const isActive = layout === initialLayout;
        link.setAttribute('aria-pressed', isActive ? 'true' : 'false');
        link.addEventListener('click', (event) => {
          event.preventDefault();
          const pageSize = pageSizeSelect?.value || initialPageSize;
          const sortBy = sortSelect?.value || toolbarUrl.searchParams.get('sort_by');
          navigateCatalog(layout, pageSize, sortBy);
        });
      });

      if (pageSizeSelect) {
        pageSizeSelect.value = initialPageSize;
        pageSizeSelect.addEventListener('change', () => {
          const sortBy = sortSelect?.value || toolbarUrl.searchParams.get('sort_by');
          navigateCatalog(initialLayout, pageSizeSelect.value, sortBy);
        });
      }

      if (sortSelect) {
        sortSelect.addEventListener('change', () => {
          const pageSize = pageSizeSelect?.value || initialPageSize;
          navigateCatalog(initialLayout, pageSize, sortSelect.value);
        });
      }
    },
    { once: true }
  );

  if (shouldFocusResults) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const catalogPanel = document.querySelector('.vanagain-catalog-filter-panel');
        const resultsList = document.getElementById('ResultsList');

        if (catalogPanel) {
          catalogPanel.open = false;
        }

        if (resultsList) {
          requestAnimationFrame(() => {
            resultsList.scrollIntoView({ behavior: 'auto', block: 'start' });
          });
        }
      },
      { once: true }
    );
  } else if (url.hash) {
    document.addEventListener(
      'DOMContentLoaded',
      () => {
        const target = document.getElementById(url.hash.slice(1));
        if (target) {
          target.scrollIntoView({ behavior: 'auto' });
        }
      },
      { once: true }
    );
  }
{% endjavascript %}

{% comment %} We always render this full-width, as the child blocks have width: page/full settings {% endcomment %}
<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<results-list
  class="section product-grid-container color-{{ section.settings.color_scheme }}{% if collection.handle == 'all' %} vanagain-all-catalog{% endif %}"
  style="--padding-block-start: {{ section.settings.padding-block-start }}px; --padding-block-end: {{ section.settings.padding-block-end }}px;"
  section-id="{{ section.id }}"
  infinite-scroll="{{ section.settings.enable_infinite_scroll }}"
>
  {% render 'skip-to-content-link', href: '#ResultsList', text: 'accessibility.skip_to_results_list' %}

  <div
    class="collection-wrapper grid gap-style{% if section.settings.product_grid_width == 'full-width' %} collection-wrapper--grid-full-width{% endif %}"
  >
    {% liquid
      assign is_vanagain_all_catalog = false
      if collection.handle == 'all'
        assign is_vanagain_all_catalog = true
      endif
      assign vanagain_catalog_layout = section.settings.vanagain_catalog_layout | default: 'grid'
    %}

    {% if is_vanagain_all_catalog %}
      <aside class="facets-block-wrapper facets-block-wrapper--vertical vanagain-catalog-filters-wrapper">
        <details class="vanagain-catalog-filter-panel">
          <summary class="vanagain-catalog-filter-panel__summary">
            <span>
              <strong>Find parts</strong>
              <small>Choose a vehicle year range, model, or part system.</small>
            </span>
            <span class="vanagain-catalog-filter-panel__action">Filter catalog</span>
          </summary>
          <div class="vanagain-catalog-filter-panel__body">
            {% render 'vanagain-catalog-filters', catalog_url: collection.url %}
          </div>
        </details>
      </aside>
    {% else %}
      {% content_for 'block',
        type: 'filters',
        id: 'filters',
        results: collection,
        results_size: collection.products_count
      %}
    {% endif %}

    {% if is_vanagain_all_catalog %}
      <div class="vanagain-collection-results vanagain-collection-results--{{ vanagain_catalog_layout }}">
    {% endif %}

    {% assign products_per_page = 24 %}

    {% if section.settings.enable_infinite_scroll == false %}
      {% assign products_per_page = section.settings.products_per_page %}
    {% endif %}

    {% paginate collection.products by products_per_page %}
      {% if is_vanagain_all_catalog %}
        {% assign current_sort = collection.sort_by | default: collection.default_sort_by %}
        {% assign current_view = vanagain_catalog_layout | append: '-' | append: products_per_page %}
        <div class="vanagain-results-toolbar" data-vanagain-catalog-toolbar data-current-view="{{ current_view }}">
          <p>
            <strong>Showing {{ collection.products.size }} of {{ collection.products_count }}</strong>
            <span>products</span>
          </p>
          <div class="vanagain-results-toolbar__controls">
            <div class="vanagain-results-toolbar__layout" aria-label="Product layout">
              <a
                href="{{ collection.url }}?view=grid-{{ products_per_page }}#ResultsList"
                data-vanagain-layout-link
                data-layout="grid"
                {% if vanagain_catalog_layout == 'grid' %}aria-pressed="true"{% else %}aria-pressed="false"{% endif %}
              >
                Grid
              </a>
              <a
                href="{{ collection.url }}?view=compact-{{ products_per_page }}#ResultsList"
                data-vanagain-layout-link
                data-layout="compact"
                {% if vanagain_catalog_layout == 'compact' %}aria-pressed="true"{% else %}aria-pressed="false"{% endif %}
              >
                Compact
              </a>
            </div>
            <label class="vanagain-results-toolbar__select">
              <span>Show</span>
              <select data-vanagain-page-size-select aria-label="Products per page">
                <option value="24" {% if products_per_page == 24 %}selected{% endif %}>24</option>
                <option value="48" {% if products_per_page == 48 %}selected{% endif %}>48</option>
                <option value="100" {% if products_per_page == 100 %}selected{% endif %}>100</option>
              </select>
            </label>
            <label class="vanagain-results-toolbar__select">
              <span>Sort</span>
              <select data-vanagain-sort-select aria-label="Sort products">
                {% for option in collection.sort_options %}
                  <option value="{{ option.value }}" {% if option.value == current_sort %}selected{% endif %}>
                    {{ option.name }}
                  </option>
                {% endfor %}
              </select>
            </label>
          </div>
        </div>
      {% endif %}

      {% capture children %}
        {% for product in collection.products %}
          <li
            id="{{ section.id }}-{{ product.id }}"
            class="product-grid__item product-grid__item--{{ forloop.index0 }}"
            data-page="{{ paginate.current_page }}"
            data-product-id="{{ product.id }}"
            ref="cards[]"
          >
            {% # theme-check-disable %}
            {% content_for 'block', type: '_product-card', id: 'product-card', closest.product: product %}
            {% # theme-check-enable %}
          </li>
        {% endfor %}
      {% endcapture %}

      {% render 'product-grid',
        section: section,
        children: children,
        products: collection.products,
        paginate: paginate,
        enable_infinite_scroll: section.settings.enable_infinite_scroll
      %}
    {% endpaginate %}

    {% if is_vanagain_all_catalog %}
      </div>
    {% endif %}
  </div>
</results-list>

{% schema %}
{
  "name": "t:names.collection_container",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "select",
      "id": "vanagain_catalog_layout",
      "label": "VanAgain catalog layout",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
        },
        {
          "value": "compact",
          "label": "Compact"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "layout_type",
      "label": "t:settings.type",
      "options": [
        {
          "value": "grid",
          "label": "t:options.grid"
        },
        {
          "value": "organic",
          "label": "t:options.editorial"
        }
      ],
      "default": "grid"
    },
    {
      "type": "select",
      "id": "product_card_size",
      "label": "t:settings.card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "medium",
          "label": "t:options.medium"
        },
        {
          "value": "large",
          "label": "t:options.large"
        },
        {
          "value": "extra-large",
          "label": "t:options.extra_large"
        }
      ],
      "default": "medium",
      "visible_if": "{{ section.settings.layout_type == 'grid' }}"
    },
    {
      "type": "select",
      "id": "mobile_product_card_size",
      "label": "t:settings.mobile_card_size",
      "options": [
        {
          "value": "small",
          "label": "t:options.small"
        },
        {
          "value": "large",
          "label": "t:options.large"
        }
      ],
      "default": "small"
    },
    {
      "type": "checkbox",
      "id": "enable_infinite_scroll",
      "label": "t:settings.auto_load_products",
      "default": true
    },
    {
      "type": "range",
      "id": "products_per_page",
      "label": "t:settings.products_per_page",
      "min": 8,
      "max": 100,
      "step": 4,
      "default": 24,
      "visible_if": "{{ section.settings.enable_infinite_scroll == false }}"
    },
    {
      "type": "header",
      "content": "t:content.layout"
    },
    {
      "type": "select",
      "id": "product_grid_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "centered",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "centered"
    },
    {
      "type": "checkbox",
      "id": "full_width_on_mobile",
      "label": "t:settings.full_width_on_mobile",
      "default": true,
      "visible_if": "{{ section.settings.product_grid_width != 'full-width' }}"
    },
    {
      "type": "range",
      "id": "columns_gap_horizontal",
      "label": "t:settings.horizontal_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "columns_gap_vertical",
      "label": "t:settings.vertical_gap",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "t:content.section_layout"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom_padding",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": []
}
{% endschema %}
