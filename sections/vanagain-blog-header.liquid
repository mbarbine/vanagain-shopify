<section class="vanagain-blog-header section section--page-width">
  <div class="vanagain-blog-header__intro">
    <p class="vanagain-blog-header__eyebrow">VanAgain Journal</p>
    <h1>The VanAgain Blog</h1>
    <p>Tips, how-to guides, and stories from the VW van community.</p>
  </div>

  <nav class="vanagain-blog-header__categories" aria-label="Blog categories">
    <a href="{{ blog.url | default: '/blogs/news' }}">All Posts</a>
    {% if blog != blank and blog.all_tags != blank %}
      {% for tag in blog.all_tags limit: 24 %}
        <a href="{{ blog.url | default: '/blogs/news' }}/tagged/{{ tag | handleize }}">{{ tag }}</a>
      {% endfor %}
    {% endif %}
  </nav>
</section>

{% stylesheet %}
  .vanagain-blog-header {
    padding-block: 2.25rem 1.5rem;
  }

  .vanagain-blog-header__intro h1 {
    margin: 0.25rem 0 0.6rem;
    font-size: clamp(1.75rem, 3.5vw, 2.6rem);
  }

  .vanagain-blog-header__eyebrow {
    margin: 0;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #1a6b8a;
    font-weight: 700;
  }

  .vanagain-blog-header__intro p {
    margin: 0;
    color: #4b5563;
  }

  .vanagain-blog-header__categories {
    margin-top: 1.1rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .vanagain-blog-header__categories a {
    border: 1px solid #d7e4eb;
    border-radius: 999px;
    padding: 0.42rem 0.72rem;
    font-size: 0.85rem;
    text-decoration: none;
    color: #234155;
    background: #ffffff;
  }

  .vanagain-blog-header__categories a:hover {
    color: #ffffff;
    background: #1a6b8a;
    border-color: #1a6b8a;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "VanAgain Blog Header",
  "settings": [],
  "presets": [
    {
      "name": "VanAgain Blog Header"
    }
  ]
}
{% endschema %}