{% doc %}
  Renders all meta tags for the page including Open Graph, Twitter Cards, and SEO tags.

  @param {object} [product] - The product object, available on product pages for price meta tags.
{% enddoc %}

<meta charset="utf-8">
<meta
  http-equiv="X-UA-Compatible"
  content="IE=edge"
>
<meta
  name="viewport"
  content="width=device-width,initial-scale=1"
>
<meta
  name="view-transition"
  content="same-origin"
>
<meta
  name="theme-color"
  content=""
>

{%- liquid
  assign og_title = page_title | default: shop.name
  assign og_url = canonical_url | default: request.origin
  assign og_type = 'website'
  assign og_description = page_description | default: shop.description | default: shop.name
  assign og_locale = request.locale.iso_code | default: 'en-US' | replace: '-', '_'
  assign og_image = page_image
  assign og_image_width = page_image.width
  assign og_image_height = page_image.height
  assign og_image_alt = og_title
  assign fallback_social_image = 'vanagain-hero.jpg' | asset_url | prepend: 'https:'

  if request.page_type == 'product'
    assign og_type = 'product'
    if product.featured_image
      assign og_image = product.featured_image
      assign og_image_width = product.featured_image.width
      assign og_image_height = product.featured_image.height
      assign og_image_alt = product.title
    endif
  elsif request.page_type == 'article'
    assign og_type = 'article'
  elsif request.page_type == 'password'
    assign og_url = request.origin
  endif
%}

<meta
  property="og:site_name"
  content="{{ shop.name }}"
>
<meta
  property="og:url"
  content="{{ og_url }}"
>
<meta
  property="og:title"
  content="{{ og_title | escape }}"
>
<meta
  property="og:type"
  content="{{ og_type }}"
>
<meta
  property="og:description"
  content="{{ og_description | escape }}"
>
<meta
  property="og:locale"
  content="{{ og_locale }}"
>

{%- for language in localization.available_languages -%}
  {%- assign alternate_locale = language.iso_code | replace: '-', '_' -%}
  {%- unless alternate_locale == og_locale -%}
    <meta property="og:locale:alternate" content="{{ alternate_locale | escape }}">
  {%- endunless -%}
{%- endfor -%}

{%- if og_image -%}
  <meta
    property="og:image"
    content="https:{{ og_image | image_url: width: 1200 }}"
  >
  <meta
    property="og:image:secure_url"
    content="https:{{ og_image | image_url: width: 1200 }}"
  >
  <meta
    property="og:image:width"
    content="{{ og_image_width }}"
  >
  <meta
    property="og:image:height"
    content="{{ og_image_height }}"
  >
  <meta
    property="og:image:alt"
    content="{{ og_image_alt | escape }}"
  >
{%- else -%}
  <meta property="og:image" content="{{ fallback_social_image }}">
  <meta property="og:image:secure_url" content="{{ fallback_social_image }}">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="{{ shop.name | escape }} VW van parts catalog">
{%- endif -%}

{%- if request.page_type == 'product' -%}
  <meta
    property="og:price:amount"
    content="{{ product.price | money_without_currency | strip_html }}"
  >
  <meta
    property="og:price:currency"
    content="{{ cart.currency.iso_code }}"
  >
{%- endif -%}

{%- if settings.social_twitter_link != blank -%}
  <meta
    name="twitter:site"
    content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}"
  >
{%- endif -%}
<meta
  name="twitter:card"
  content="summary_large_image"
>
<meta
  name="twitter:title"
  content="{{ og_title | escape }}"
>
<meta
  name="twitter:description"
  content="{{ og_description | escape }}"
>
<meta
  name="twitter:url"
  content="{{ og_url }}"
>
{%- if og_image -%}
  <meta
    name="twitter:image"
    content="https:{{ og_image | image_url: width: 1200 }}"
  >
  <meta
    name="twitter:image:alt"
    content="{{ og_image_alt | escape }}"
  >
{%- else -%}
  <meta name="twitter:image" content="{{ fallback_social_image }}">
  <meta name="twitter:image:alt" content="{{ shop.name | escape }} VW van parts catalog">
{%- endif -%}
<meta
  name="shopify-market"
  content="{{ localization.country.iso_code | default: 'US' }} {{ localization.country.currency.iso_code | default: cart.currency.iso_code | default: shop.currency }}"
>
<meta
  name="shipping-destinations"
  content="United States, U.S. territories, Canada, Mexico, Europe, Australia, and other destinations supported at checkout"
>

<title>
  {{ page_title }}
  {%- if current_tags %} &ndash; tagged "{{ current_tags | join: ', ' }}"{% endif -%}
  {%- if current_page != 1 %} &ndash; Page {{ current_page }}{% endif -%}
  {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
</title>

<link
  rel="canonical"
  href="{{ canonical_url }}"
>

{% if page_description %}
  <meta
    name="description"
    content="{{ page_description | escape }}"
  >
{% endif %}

{%- liquid
  capture vanagain_keywords
    echo 'VanAgain, VW parts, Vanagon parts, VW Bus parts, Eurovan parts'
    if request.page_type == 'product' and product.tags.size > 0
      echo ', '
      echo product.tags | join: ', '
    elsif request.page_type == 'article' and article.tags.size > 0
      echo ', '
      echo article.tags | join: ', '
    elsif current_tags
      echo ', '
      echo current_tags | join: ', '
    elsif request.page_type == 'collection' and collection.title != blank
      echo ', '
      echo collection.title
    elsif request.page_type == 'page' and page.title != blank
      echo ', '
      echo page.title
    endif
  endcapture
  assign vanagain_keywords = vanagain_keywords | strip | strip_newlines
-%}

<meta
  name="keywords"
  content="{{ vanagain_keywords | escape }}"
>

{%- if request.page_type == 'product' and product.tags.size > 0 -%}
  {%- for tag in product.tags limit: 20 -%}
    <meta name="product:tag" content="{{ tag | escape }}">
  {%- endfor -%}
{%- elsif request.page_type == 'article' and article.tags.size > 0 -%}
  {%- for tag in article.tags limit: 20 -%}
    <meta property="article:tag" content="{{ tag | escape }}">
  {%- endfor -%}
{%- elsif current_tags -%}
  {%- for tag in current_tags limit: 20 -%}
    <meta name="content:tag" content="{{ tag | escape }}">
  {%- endfor -%}
{%- endif -%}
