        <li class="menu-drawer__list-item"><a class="menu-drawer__menu-item menu-drawer__menu-item--child focus-inset" href="{{ privacy_url }}"><span class="menu-drawer__menu-item-text wrap-text">Privacy Policy</span></a></li>
        {% if shop.terms_of_service != blank %}
