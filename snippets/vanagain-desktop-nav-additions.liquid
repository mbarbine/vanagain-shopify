{%- doc -%}
  Appends VanAgain content-page groups when the Shopify main menu does not already
  include equivalent top-level groups.

  @param {object} linklist - The configured Shopify navigation menu
{%- enddoc -%}

{% liquid
  assign menu_titles = '|'
  for link in linklist.links
    assign normalized_title = link.title | downcase | strip
    assign menu_titles = menu_titles | append: normalized_title | append: '|'
  endfor
  assign catalog_url = routes.all_products_collection_url
  assign search_url = routes.search_url
  assign privacy_url = '/policies/privacy-policy'
  assign terms_url = '/policies/terms-of-service'

  if shop.privacy_policy != blank
    assign privacy_url = shop.privacy_policy.url
  endif

  if shop.terms_of_service != blank
    assign terms_url = shop.terms_of_service.url
  endif
%}

{% unless menu_titles contains '|parts|' %}
  <li class="menu-list__list-item vanagain-nav-group vanagain-nav-group--parts" role="presentation">
    <details class="vanagain-nav-details">
      <summary class="menu-list__link vanagain-nav-summary">
        <span class="menu-list__link-title">Parts</span>
      </summary>
      <div class="vanagain-nav-menu vanagain-nav-menu--wide">
        <div class="vanagain-nav-menu__section">
          <h3>Shop by vehicle</h3>
          <a href="{{ catalog_url }}/86-92-21l-vanagon?filter.v.availability=1">86-92 Vanagon</a>
          <a href="{{ catalog_url }}/83-85-19l-vanagon?filter.v.availability=1">83-85 Vanagon</a>
          <a href="{{ catalog_url }}/68-79-bus?filter.v.availability=1">68-79 Bus</a>
          <a href="{{ catalog_url }}/92-96-25l-eurovan?filter.v.availability=1">Eurovan</a>
        </div>
        <div class="vanagain-nav-menu__section">
          <h3>Popular systems</h3>
          <a href="{{ catalog_url }}/coolant-system?filter.v.availability=1">Coolant System</a>
          <a href="{{ catalog_url }}/engine-parts?filter.v.availability=1">Engine Parts</a>
          <a href="{{ catalog_url }}/brakes?filter.v.availability=1">Brakes</a>
          <a href="{{ catalog_url }}/transmission-drivetrain?filter.v.availability=1">Transmission &amp; Drivetrain</a>
        </div>
        <div class="vanagain-nav-menu__section vanagain-nav-menu__section--featured">
          <h3>Catalog</h3>
          <a href="{{ catalog_url }}?filter.v.availability=1">In-stock parts</a>
          <a href="{{ catalog_url }}">All products</a>
          <a href="{{ search_url }}?type=product&options%5Bprefix%5D=last">Search by part or SKU</a>
        </div>
      </div>
    </details>
  </li>
{% endunless %}

{% unless menu_titles contains '|support|' %}
  <li class="menu-list__list-item vanagain-nav-group" role="presentation">
    <details class="vanagain-nav-details">
      <summary class="menu-list__link vanagain-nav-summary">
        <span class="menu-list__link-title">Support</span>
      </summary>
      <div class="vanagain-nav-menu">
        <a href="/pages/faq">FAQ</a>
        <a href="{% if shop.shipping_policy != blank %}{{ shop.shipping_policy.url }}{% else %}/pages/shipping{% endif %}">Shipping</a>
        <a href="{% if shop.refund_policy != blank %}{{ shop.refund_policy.url }}{% else %}/pages/returns{% endif %}">Returns</a>
        <a href="/pages/track-order">Track Order</a>
        <a href="/pages/contact">Contact</a>
      </div>
    </details>
  </li>
{% endunless %}

{% unless menu_titles contains '|company|' %}
  <li class="menu-list__list-item vanagain-nav-group" role="presentation">
    <details class="vanagain-nav-details">
      <summary class="menu-list__link vanagain-nav-summary">
        <span class="menu-list__link-title">Company</span>
      </summary>
      <div class="vanagain-nav-menu">
        <a href="/pages/about">About</a>
        <a href="/blogs/news">Blog</a>
        <a href="/pages/rewards">Rewards</a>
        <a href="/pages/testimonials">Testimonials</a>
      </div>
    </details>
  </li>
{% endunless %}

{% unless menu_titles contains '|resources|' %}
  <li class="menu-list__list-item vanagain-nav-group" role="presentation">
    <details class="vanagain-nav-details">
      <summary class="menu-list__link vanagain-nav-summary">
        <span class="menu-list__link-title">Resources</span>
      </summary>
      <div class="vanagain-nav-menu">
        <a href="/pages/vw-accessories">VW Accessories</a>
        <a href="/pages/llms-txt">LLMs.txt</a>
        <a href="/pages/seo">SEO Reference</a>
        <a href="/pages/aeo">AEO Reference</a>
        <a href="/pages/geo">GEO Reference</a>
        <a href="{{ privacy_url }}">Privacy Policy</a>
        <a href="{{ terms_url }}">Terms of Service</a>
      </div>
    </details>
  </li>
{% endunless %}
